{
  "servers": {
    "github": {
      "command": "docker",
      "args": [
        "run",
        "-i", 
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN=${env:GITHUB_TOKEN}",
        "-e", 
        "GITHUB_TOOLSETS=repos,users,pull_requests,issues",
        "ghcr.io/github/github-mcp-server"
      ]
    }
  }
}
